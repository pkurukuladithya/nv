# =============================================
# IoT Sensor Dashboard - Backend Environment
# =============================================

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/iot_sensors?retryWrites=true&w=majority

# Server port
PORT=5000

# CORS origin - set to your frontend URL
# Development: http://localhost:5173
# Production (Vercel): https://your-frontend.vercel.app
CORS_ORIGIN=http://localhost:5173

# =============================================
# MQTT Broker Settings
# =============================================
# Public HiveMQ broker (no auth needed for testing):
MQTT_BROKER_URL=mqtt://broker.hivemq.com
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Topic pattern to subscribe to (+ is a single-level wildcard)
MQTT_TOPIC_PATTERN=devices/+/readings
