# =============================================
# IoT Sensor Dashboard - Frontend Environment
# =============================================

# Backend API base URL
# Development: http://localhost:5000/api
# Production (Render): https://your-backend.onrender.com/api
VITE_API_BASE_URL=http://localhost:5000/api

# MQTT broker settings (required for realtime WebSocket mode)
# If not set, frontend will fallback to periodic HTTP polling.
VITE_MQTT_BROKER_URL=wss://your-broker-host:8884/mqtt
VITE_MQTT_USERNAME=your-mqtt-username
VITE_MQTT_PASSWORD=your-mqtt-password
VITE_MQTT_TOPIC=devices/+/readings
